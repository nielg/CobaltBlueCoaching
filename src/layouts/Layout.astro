---
import '../styles/global.css'
import { Image } from 'astro:assets';
import logo from '../assets/logo.png'
import Nav from '../components/Nav.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>Cobalt Blue Coaching</title>
	</head>
	<body>
		<header>
			<a id="left-header" href={import.meta.env.BASE_URL}>
				<Image id="logo" src={logo} alt="Cobalt Blue loge"/>
				<h2><span class="blue-text">Cobalt Blue </span>Coaching</h2>

			</a>
			<Nav/>
		</header>
		<main>
			<slot />
		</main>
		<footer class="white-text">
			<p class="border-bottom" style="white-space: pre-wrap;">Tel. +32 470 61 23 07      |      info@cobaltbluecoaching.be</p>
			<p>© 2020 Cobalt blue coaching</p>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background-color: var(--bg-white);
		color: var(--text);
	}

	header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 2rem 5%;
	}

	#left-header{
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	#logo{
		width: 5rem;
		height: auto;
	}


	footer {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		margin: auto;
		padding: 2rem;
		background-color: var(--bg-dark);
	}


	footer .border-bottom{
		border-bottom: 1px solid var(--text-gray);
		padding: 0 1rem 2rem 1rem;
	}
</style>
